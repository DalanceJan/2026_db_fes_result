                aValue = String(aValue).toLowerCase();
                bValue = String(bValue).toLowerCase();
                
                if (currentSortDirection === 'asc') {
                    return aValue.localeCompare(bValue, 'zh');
                } else {
                    return bValue.localeCompare(aValue, 'zh');
                }
            });
            
            renderTable();
            updateSortIndicators();
        }

        // 更新排序指示器
        function updateSortIndicators() {
            document.querySelectorAll('th').forEach((th, index) => {
                th.classList.remove('sorted-asc', 'sorted-desc');
            });
            
            if (currentSortColumn) {
                const headers = ['Match Index', 'Match Time', 'Match Set', 'Lane', 'Team Name', 'Qualifying Score', 'Match Score', 'Rank', 'Match Name'];
                const index = headers.indexOf(currentSortColumn);
                if (index !== -1) {
                    document.querySelectorAll('th')[index].classList.add(`sorted-${currentSortDirection}`);
                }
            }
        }

        // 渲染表格
        function renderTable() {
            const tableBody = document.getElementById('tableBody');
            const noData = document.getElementById('noData');
            
            if (filteredData.length === 0) {
                tableBody.innerHTML = '';
                noData.style.display = 'block';
                return;
            }
            
            noData.style.display = 'none';
            tableBody.innerHTML = filteredData.map(row => `
                <tr>
                    <td>${row['Match Index'] || '-'}</td>
                    <td class="time-cell">${row['Match Time'] || '-'}</td>
                    <td>${row['Match Set'] || '-'}</td>
                    <td>${row['Lane'] || '-'}</td>
                    <td><strong>${row['Team Name'] || '-'}</strong></td>
                    <td>${row['Qualifying Score'] || '-'}</td>
                    <td class="time-cell">${row['Match Score'] || '-'}</td>
                    <td class="rank-cell">${row['Rank'] || '-'}</td>
                    <td>${row['Match Name'] || '-'}</td>
                </tr>
            `).join('');
        }

        // 更新統計信息
        function updateStats() {
            document.getElementById('totalCount').textContent = allData.length;
            document.getElementById('showCount').textContent = filteredData.length;
        }

        // 事件監聽器
        document.getElementById('filterInput').addEventListener('input', filterData);

        // 页面加载完成后初始化
        window.addEventListener('DOMContentLoaded', initialize);
    </script>
</body>
</html>
